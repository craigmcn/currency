{
  "name": "currency",
  "version": "2.5.0",
  "description": "A very simple currency conversion calculator",
  "scripts": {
    "build": "vite build",
    "build:netlify": "vite build --outDir netlify && vite build --outDir netlify/currency",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src e2e playwright.config.ts",
    "lint:fix": "eslint src e2e playwright.config.ts --fix",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "keywords": [
    "currency",
    "conversion",
    "convert",
    "calculator",
    "calculate"
  ],
  "author": "Craig McNaughton",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@fortawesome/duotone-light-svg-icons": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "ipdata": "^3.0.0",
    "react": "^19.1.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.1.0",
    "react-select": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10",
    "vitest-axe": "1.0.0-pre.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craigmcn/currency.git"
  },
  "packageManager": "yarn@4.14.1",
  "resolutions": {
    "minimatch@^3.1.2": "^3.1.5",
    "minimatch@^9.0.4": "^9.0.7",
    "picomatch@^4.0.2": "^4.0.4",
    "tar": "^7.5.16",
    "glob": "^10.5.0",
    "yaml@^1.10.0": "^1.10.3",
    "flatted": "^3.4.2",
    "undici@^7.25.0": "^7.28.0",
    "socks": "^2.8.9",
    "vite@^6.0.0 || ^7.0.0 || ^8.0.0": "^8.1.3"
  }
}
