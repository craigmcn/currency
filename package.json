{
  "name": "currency",
  "version": "2.5.0",
  "description": "A very simple currency conversion calculator",
  "scripts": {
    "build": "vite build",
    "build:netlify": "vite build --outDir netlify && vite build --outDir netlify/currency",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "keywords": [
    "currency",
    "conversion",
    "convert",
    "calculator",
    "calculate"
  ],
  "author": "Craig McNaughton",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@fortawesome/duotone-light-svg-icons": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "ipdata": "^2.2.4",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.1.0",
    "react-select": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash": "^4.17.16",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craigmcn/currency.git"
  },
  "packageManager": "yarn@4.14.1"
}
