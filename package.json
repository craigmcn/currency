{
  "name": "currency",
  "version": "2.5.0",
  "description": "A very simple currency conversion calculator",
  "scripts": {
    "build": "vite build",
    "build:netlify": "vite build --outDir netlify && vite build --outDir netlify/currency",
    "dev": "vite",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "preview": "vite preview",
    "start": "vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "currency",
    "conversion",
    "convert",
    "calculator",
    "calculate"
  ],
  "author": "Craig McNaughton",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@fortawesome/duotone-light-svg-icons": "^6.7.2",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "ipdata": "^2.2.4",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.1.0",
    "react-select": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.8",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.25.1",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@types/lodash": "^4.17.16",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.25.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "sass": "^1.87.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craigmcn/currency.git"
  },
